---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { navFor } from '../../lib/nav';
import { courseById } from '../../lib/courses';
import { niveauxFor } from '../../lib/fiability';

const courseId = 'cosmologie';
const course = courseById(courseId)!;
const all = navFor(courseId);
const parties = all.filter((p) => p.id !== 'annexes' && p.id !== 'introduction');
const niveaux = niveauxFor(courseId);
const premier = parties[0]?.chapitres[0]?.path ?? course.home;
---

<BaseLayout title={course.title} courseId={courseId} showSidebar={false}>
  <main class="home cosmo" data-pagefind-body>
    <section class="hero">
      <div class="hero-bg" aria-hidden="true"></div>
      <div class="hero-inner">
        <p class="kicker"><a href="/">← Tous les cours</a></p>
        <h1>{course.logo} {course.title}</h1>
        <p class="tagline">{course.blurb}</p>
        <div class="cta">
          <a class="btn primary" href="/cosmologie/comment-lire">Comment lire ce cours</a>
          <a class="btn" href={premier}>Commencer →</a>
        </div>
      </div>
    </section>

    <section>
      <h2>L’indicateur de fiabilité (cosmologie)</h2>
      <div class="niv-grid">
        {niveaux.map((n) => (
          <div class="niv" style={`--cc:${n.color}`}>
            <span class="d" /><strong>{n.emoji} {n.label}</strong>
          </div>
        ))}
      </div>
    </section>

    <section>
      <h2>Le parcours, en six parties</h2>
      <div class="parts">
        {parties.map((p) => (
          <a class="partcard" href={p.chapitres[0].path}>
            <div class="pc-roman">{p.roman}</div>
            <div class="pc-body">
              <h3>{p.titre}</h3>
              <p>{p.accroche}</p>
              <span class="pc-count">{p.chapitres.length} chapitre{p.chapitres.length > 1 ? 's' : ''} →</span>
            </div>
          </a>
        ))}
      </div>
    </section>

    <footer class="home-foot">
      <p>Annexes : <a href="/cosmologie/glossaire">glossaire</a> · <a href="/cosmologie/symboles">index des symboles</a>.</p>
    </footer>
  </main>

  <style>
    /* L'accent du cours « cosmologie » est l'orange (Λ / ΛCDM). */
    .home.cosmo .kicker,
    .home.cosmo .pc-roman,
    .home.cosmo .pc-count { color: var(--c-orange); }
    .home.cosmo .btn.primary { background: var(--c-orange); color: #1a1206; border-color: var(--c-orange); }
    .home.cosmo .btn:hover { border-color: var(--c-orange); }
    .home.cosmo .partcard:hover { border-color: var(--c-orange); }
  </style>
</BaseLayout>
