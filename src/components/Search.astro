---
/**
 * Recherche interne — s'appuie sur Pagefind (index généré au build :
 * `astro build && pagefind --site dist`). En développement, l'index n'existe pas
 * encore : le composant le signale proprement.
 *
 * Ouverture : clic sur le bouton, ou touche « / ». Fermeture : Échap / clic hors zone.
 */
---

<button id="search-open" class="search-open" type="button" aria-label="Rechercher (touche /)" title="Rechercher  /">
  <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
    <circle cx="11" cy="11" r="7" fill="none" stroke="currentColor" stroke-width="2"></circle>
    <line x1="16.5" y1="16.5" x2="21" y2="21" stroke="currentColor" stroke-width="2" stroke-linecap="round"></line>
  </svg>
  <span class="kbd">/</span>
</button>

<div id="search-modal" class="search-modal" hidden>
  <div class="search-backdrop" data-close></div>
  <div class="search-panel" role="dialog" aria-modal="true" aria-label="Recherche">
    <button class="search-close" data-close aria-label="Fermer la recherche">✕</button>
    <div id="pagefind-search" data-pagefind-ui></div>
    <p class="search-dev" id="search-dev" hidden>
      🔍 La recherche est générée au moment du build. Lancez
      <code>npm run build &amp;&amp; npm run preview</code> pour l’essayer.
    </p>
  </div>
</div>

<script>
  const openBtn = document.getElementById('search-open');
  const modal = document.getElementById('search-modal');
  const devMsg = document.getElementById('search-dev');
  let loaded = false;

  async function loadPagefind() {
    if (loaded) return;
    loaded = true;
    try {
      // CSS
      const css = document.createElement('link');
      css.rel = 'stylesheet';
      css.href = '/pagefind/pagefind-ui.css';
      document.head.appendChild(css);
      // JS chargé en <script> classique (Pagefind expose window.PagefindUI).
      // On l'injecte dynamiquement pour ne pas dépendre, au build, d'un fichier
      // qui n'est généré qu'APRÈS (postbuild pagefind). Échoue proprement en dev.
      await new Promise<void>((resolve, reject) => {
        const existing = document.querySelector('script[data-pagefind-js]');
        if (existing) return resolve();
        const s = document.createElement('script');
        s.src = '/pagefind/pagefind-ui.js';
        s.dataset.pagefindJs = '1';
        s.onload = () => resolve();
        s.onerror = () => reject(new Error('pagefind indisponible'));
        document.head.appendChild(s);
      });
      // @ts-ignore — défini par le script Pagefind chargé ci-dessus
      new window.PagefindUI({
        element: '#pagefind-search',
        showSubResults: true,
        showImages: false,
        translations: {
          placeholder: 'Rechercher dans le site…',
          clear_search: 'Effacer',
          load_more: 'Voir plus de résultats',
          search_label: 'Recherche',
          zero_results: 'Aucun résultat pour « [SEARCH_TERM] »',
          many_results: '[COUNT] résultats pour « [SEARCH_TERM] »',
          one_result: '1 résultat pour « [SEARCH_TERM] »',
          searching: 'Recherche de « [SEARCH_TERM] »…',
        },
      });
    } catch {
      devMsg?.removeAttribute('hidden');
    }
  }

  function open() {
    if (!modal) return;
    modal.removeAttribute('hidden');
    document.body.style.overflow = 'hidden';
    loadPagefind();
    setTimeout(() => modal.querySelector<HTMLInputElement>('input')?.focus(), 60);
  }
  function close() {
    if (!modal) return;
    modal.setAttribute('hidden', '');
    document.body.style.overflow = '';
  }

  openBtn?.addEventListener('click', open);
  modal?.querySelectorAll('[data-close]').forEach((el) => el.addEventListener('click', close));
  document.addEventListener('keydown', (e) => {
    if (e.key === '/' && !/^(INPUT|TEXTAREA)$/.test((e.target as HTMLElement)?.tagName)) {
      e.preventDefault();
      open();
    } else if (e.key === 'Escape') {
      close();
    }
  });
</script>

<style>
  .search-open {
    display: inline-flex;
    align-items: center;
    gap: 0.4em;
    height: 38px;
    padding: 0 0.7em;
    border: 1px solid var(--c-border);
    background: var(--c-surface);
    color: var(--c-muted);
    border-radius: 10px;
    cursor: pointer;
  }
  .search-open:hover {
    color: var(--c-blue);
    background: var(--c-surface-2);
  }
  .kbd {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    border: 1px solid var(--c-border);
    border-radius: 5px;
    padding: 0 0.4em;
    background: var(--c-bg);
  }
  @media (max-width: 560px) {
    .kbd {
      display: none;
    }
  }
  .search-modal[hidden] {
    display: none;
  }
  .search-modal {
    position: fixed;
    inset: 0;
    z-index: 200;
    display: grid;
    place-items: start center;
    padding-top: 9vh;
  }
  .search-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(2, 6, 12, 0.6);
    backdrop-filter: blur(2px);
  }
  .search-panel {
    position: relative;
    width: min(640px, 92vw);
    max-height: 75vh;
    overflow: auto;
    background: var(--c-bg-elev);
    border: 1px solid var(--c-border);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    padding: 1.4em 1.2em 1.2em;
  }
  .search-close {
    position: absolute;
    top: 0.6em;
    right: 0.7em;
    background: none;
    border: none;
    color: var(--c-muted);
    font-size: 1.1rem;
    cursor: pointer;
  }
  .search-close:hover {
    color: var(--c-text);
  }
  .search-dev {
    color: var(--c-muted);
    font-size: 0.9rem;
  }
  .search-dev code {
    font-family: var(--font-mono);
    font-size: 0.82rem;
  }
  /* Habillage Pagefind aux couleurs du site */
  :global(.pagefind-ui) {
    --pagefind-ui-primary: var(--c-blue);
    --pagefind-ui-text: var(--c-text);
    --pagefind-ui-background: var(--c-bg-elev);
    --pagefind-ui-border: var(--c-border);
    --pagefind-ui-tag: var(--c-surface);
    --pagefind-ui-font: var(--font-sans);
  }
</style>
