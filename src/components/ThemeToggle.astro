---
/**
 * Bascule clair / sombre. Le thème par défaut est SOMBRE.
 * La prévention du « flash » au chargement est gérée par un script inline dans
 * BaseLayout (exécuté avant le rendu). Ce bouton ne fait que basculer + persister.
 */
---

<button
  id="theme-toggle"
  class="theme-toggle"
  type="button"
  aria-label="Basculer entre thème clair et sombre"
  title="Thème clair / sombre"
>
  <svg class="i sun" viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
    <circle cx="12" cy="12" r="4.2" fill="currentColor"></circle>
    <g stroke="currentColor" stroke-width="2" stroke-linecap="round">
      <line x1="12" y1="2" x2="12" y2="4.5"></line>
      <line x1="12" y1="19.5" x2="12" y2="22"></line>
      <line x1="2" y1="12" x2="4.5" y2="12"></line>
      <line x1="19.5" y1="12" x2="22" y2="12"></line>
      <line x1="4.5" y1="4.5" x2="6.3" y2="6.3"></line>
      <line x1="17.7" y1="17.7" x2="19.5" y2="19.5"></line>
      <line x1="4.5" y1="19.5" x2="6.3" y2="17.7"></line>
      <line x1="17.7" y1="6.3" x2="19.5" y2="4.5"></line>
    </g>
  </svg>
  <svg class="i moon" viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
    <path
      d="M21 12.8A8.5 8.5 0 1 1 11.2 3a6.6 6.6 0 0 0 9.8 9.8z"
      fill="currentColor"></path>
  </svg>
</button>

<script>
  const btn = document.getElementById('theme-toggle');
  btn?.addEventListener('click', () => {
    const root = document.documentElement;
    const courant = root.getAttribute('data-theme') === 'light' ? 'light' : 'dark';
    const suivant = courant === 'light' ? 'dark' : 'light';
    root.setAttribute('data-theme', suivant);
    try {
      localStorage.setItem('theme', suivant);
    } catch {
      /* stockage indisponible : on garde simplement la session */
    }
  });
</script>

<style>
  .theme-toggle {
    display: inline-grid;
    place-items: center;
    width: 38px;
    height: 38px;
    border: 1px solid var(--c-border);
    background: var(--c-surface);
    color: var(--c-text);
    border-radius: 10px;
    cursor: pointer;
  }
  .theme-toggle:hover {
    background: var(--c-surface-2);
    color: var(--c-blue);
  }
  .i {
    grid-area: 1 / 1;
  }
  /* sombre : on propose de passer en clair → icône soleil */
  :root[data-theme='light'] .sun {
    display: none;
  }
  :root:not([data-theme='light']) .moon {
    display: none;
  }
</style>
