---
/**
 * Fine barre de progression de lecture, fixée en haut de la fenêtre, qui suit
 * la position de défilement dans l'article courant (#contenu).
 */
---

<div class="reading-progress" role="presentation">
  <div class="rp-bar" id="rp-bar"></div>
</div>

<script>
  const bar = document.getElementById('rp-bar');
  const article = document.getElementById('contenu') ?? document.body;
  let ticking = false;

  function update() {
    if (!bar) return;
    const rect = article.getBoundingClientRect();
    const total = article.scrollHeight - window.innerHeight;
    const lu = Math.min(Math.max(-rect.top, 0), Math.max(total, 1));
    const pct = total > 0 ? (lu / total) * 100 : 0;
    bar.style.width = `${pct}%`;
    ticking = false;
  }

  function onScroll() {
    if (!ticking) {
      requestAnimationFrame(update);
      ticking = true;
    }
  }

  window.addEventListener('scroll', onScroll, { passive: true });
  window.addEventListener('resize', onScroll, { passive: true });
  update();
</script>

<style>
  .reading-progress {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    z-index: 120;
    background: transparent;
    pointer-events: none;
  }
  .rp-bar {
    height: 100%;
    width: 0%;
    background: linear-gradient(90deg, var(--c-blue), var(--c-yellow));
    transition: width 0.08s linear;
  }
</style>
