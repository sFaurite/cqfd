---
/**
 * Boutons précédent / suivant, calculés depuis l'ordre de lecture global (nav.ts).
 */
import { prevNextByPath } from '../lib/nav';
interface Props {
  currentPath: string;
}
const { currentPath } = Astro.props;
const { precedent, suivant } = prevNextByPath(currentPath);
---

<nav class="prevnext" aria-label="Navigation entre chapitres">
  {
    precedent ? (
      <a class="pn prev" href={precedent.chap.path} rel="prev">
        <span class="dir">← Précédent</span>
        <span class="t">{precedent.chap.court ?? precedent.chap.titre}</span>
      </a>
    ) : (
      <span class="pn empty" />
    )
  }
  {
    suivant ? (
      <a class="pn next" href={suivant.chap.path} rel="next">
        <span class="dir">Suivant →</span>
        <span class="t">{suivant.chap.court ?? suivant.chap.titre}</span>
      </a>
    ) : (
      <span class="pn empty" />
    )
  }
</nav>

<style>
  .prevnext {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin: 2.5rem 0 1rem;
  }
  .pn {
    display: flex;
    flex-direction: column;
    gap: 0.25em;
    padding: 0.9em 1.1em;
    border: 1px solid var(--c-border);
    border-radius: var(--radius);
    background: var(--c-bg-elev);
    color: var(--c-text);
  }
  .pn:hover {
    border-color: var(--c-blue);
    background: var(--c-surface);
    text-decoration: none;
  }
  .pn.next {
    text-align: right;
  }
  .pn.empty {
    border: none;
    background: none;
  }
  .dir {
    font-size: 0.78rem;
    color: var(--c-blue);
    font-weight: 700;
  }
  .t {
    font-weight: 600;
    line-height: 1.3;
  }
  @media (max-width: 560px) {
    .prevnext {
      grid-template-columns: 1fr;
    }
  }
</style>
