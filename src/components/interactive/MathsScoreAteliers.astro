---
/**
 * MathsScoreAteliers — le score global des ateliers « À vous ».
 * Lit, côté client, la progression sauvegardée par chaque atelier dans le
 * navigateur (localStorage : clés cqfd-ndj-v1 et cqfd-ceq-*-v1) et l'agrège :
 * une barre par atelier, une barre globale. Les exercices Lean, vérifiés
 * « hors les murs » dans l'éditeur en ligne, ne peuvent pas être comptés.
 * Le rendu des lignes est statique (liens, totaux) ; le client ne fait que
 * remplir les compteurs — la page reste lisible sans JavaScript.
 */
import { withBase } from '../../lib/base';

const ATELIERS = [
  { cle: 'cqfd-ndj-v1', total: 7, titre: 'Atelier 1 — La déduction naturelle', ou: 'chapitre 1', href: '/maths/partie-i/methode-axiomatique' },
  { cle: 'cqfd-ceq-peano-v1', total: 4, titre: 'Atelier 2 — Le calcul de ℕ : 2 + 2 = 4', ou: 'chapitre 5', href: '/maths/partie-ii/arithmetique-de-n' },
  { cle: 'cqfd-ceq-relatif-v1', total: 4, titre: 'Atelier 3 — Les promesses : la règle des signes', ou: 'chapitre 6', href: '/maths/partie-ii/entiers-relatifs' },
  { cle: 'cqfd-ceq-complexe-v1', total: 5, titre: 'Atelier 4 — Les couples : i² = −1', ou: 'chapitre 9', href: '/maths/partie-ii/complexes' },
  { cle: 'cqfd-ceq-groupe-v1', total: 4, titre: 'Atelier 5 — Les groupes : les axiomes suffisent', ou: 'chapitre 14', href: '/maths/partie-iv/groupes' },
  { cle: 'cqfd-ceq-modulo-v1', total: 5, titre: 'Atelier 6 — L’horloge : ℤ/nℤ jusqu’à Fermat', ou: 'chapitre 16', href: '/maths/partie-iv/anneaux-corps' },
];
const TOTAL = ATELIERS.reduce((s, a) => s + a.total, 0);
---

<div class="iw msa" data-iw="score-ateliers">
  <div class="iw__head"><span class="tag">Interactif</span> Votre progression, tous ateliers confondus</div>

  <div class="msa__global">
    <span class="msa__glabel">score global</span>
    <span class="msa__gbar"><span class="msa__gfill" data-gfill></span></span>
    <b class="msa__gscore" data-gscore>0/{TOTAL}</b>
  </div>

  <ul class="msa__list">
    {ATELIERS.map((a) => (
      <li class="msa__row" data-atelier={a.cle} data-total={a.total}>
        <a class="msa__lien" href={withBase(a.href)}>{a.titre}</a>
        <span class="msa__ou">{a.ou}</span>
        <span class="msa__bar"><span class="msa__fill" data-fill></span></span>
        <span class="msa__n" data-n>0/{a.total}</span>
      </li>
    ))}
  </ul>

  <p class="iw__note">
    La progression vit dans <b>votre navigateur</b> (elle n’est envoyée nulle part) : c’est celle
    que chaque atelier affiche à côté de « réussis ». Le corrigé pas à pas ne compte pas — seules
    les preuves menées à la main comptent. Les exercices Lean, vérifiés hors les murs dans
    l’éditeur en ligne, ne peuvent pas être comptés ici.
  </p>
</div>

<style is:global>
  .msa__global {
    display: flex; align-items: center; gap: 0.7rem;
    margin: 0.85rem 1rem 0.35rem; padding: 0.6rem 0.8rem;
    background: var(--c-surface); border: 1px solid var(--c-border);
    border-radius: var(--radius-sm);
  }
  .msa__glabel { color: var(--c-muted); font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.04em; flex: none; }
  .msa__gbar, .msa__bar {
    flex: 1; height: 8px; border-radius: 999px; overflow: hidden;
    background: color-mix(in srgb, var(--c-border) 55%, transparent);
  }
  .msa__gfill, .msa__fill {
    display: block; height: 100%; width: 0;
    background: var(--c-green); border-radius: inherit;
    transition: width 0.5s ease;
  }
  .msa__gscore { font-family: var(--font-mono); font-size: 1rem; color: var(--c-green); flex: none; }
  .msa__list { list-style: none; margin: 0.35rem 1rem 0.6rem; padding: 0; display: flex; flex-direction: column; gap: 0.3rem; }
  .msa__row {
    display: grid; grid-template-columns: minmax(14rem, 1.6fr) auto 1fr auto;
    align-items: center; gap: 0.6rem;
    padding: 0.4rem 0.8rem;
    background: var(--c-surface); border: 1px solid var(--c-border);
    border-radius: var(--radius-sm); font-size: 0.88rem;
  }
  .msa__row.is-complet { border-color: color-mix(in srgb, var(--c-green) 55%, var(--c-border)); }
  .msa__row.is-complet .msa__n::after { content: ' ✓'; }
  .msa__lien { color: var(--c-link); font-weight: 500; }
  .msa__lien:hover { color: var(--c-link-hover); }
  .msa__ou { color: var(--c-muted); font-size: 0.75rem; white-space: nowrap; }
  .msa__n { font-family: var(--font-mono); font-size: 0.85rem; color: var(--c-muted); min-width: 3.2ch; text-align: right; }
  .msa__row.is-complet .msa__n { color: var(--c-green); }
  @media (max-width: 640px) {
    .msa__row { grid-template-columns: 1fr auto; }
    .msa__ou, .msa__bar { display: none; }
  }
</style>

<script>
  import './MathsScoreAteliers.client.ts';
</script>
